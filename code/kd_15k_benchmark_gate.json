{
    "_comment": "15K benchmark gate: control vs ablation winner. Re-run from 5K warm-start with clean WSD schedule. save_at enables lm-eval at intermediate steps. Winner arm to be finalized after 3K ablation completes.",
    "_temperature_note": "If 3K ablation logit arms show advantage at T=2.0, keep T=2.0. If they don't, re-test with T=1.0 per Minitron evidence (see RESEARCH.md §6.4.27).",
    "name": "kd_15k_gate",
    "init_from": "results/checkpoints_probe_pgqa_100m_gate/transformer_24x512_step5000.pt",
    "total_steps": 15000,
    "batch_size": 8,
    "grad_accum": 4,
    "lr": 3e-4,
    "min_lr": 1e-5,
    "warmup": 500,
    "eval_every": 1000,
    "seq_len": 512,
    "n_spans": 16,
    "logit_temperature": 2.0,
    "logit_top_k": 64,
    "save_at": [3000, 5000, 7500, 10000, 12000, 15000],
    "variants": [
        {
            "tag": "control_15k",
            "teachers": [],
            "alpha_state": 0.0,
            "alpha_semantic": 0.0,
            "alpha_logit": 0.0
        },
        {
            "tag": "WINNER_PLACEHOLDER",
            "_note": "Replace with winning arm config from 3K ablation. See options below.",
            "teachers": [
                {"name": "Qwen/Qwen3-1.7B-Base", "surfaces": ["logit"]}
            ],
            "alpha_state": 0.0,
            "alpha_semantic": 0.0,
            "alpha_logit": 1.0
        }
    ],
    "_winner_options": {
        "logit_only": {
            "tag": "logit_15k",
            "teachers": [{"name": "Qwen/Qwen3-1.7B-Base", "surfaces": ["logit"]}],
            "alpha_state": 0.0, "alpha_semantic": 0.0, "alpha_logit": 1.0
        },
        "rep_plus_logit": {
            "tag": "rep_logit_15k",
            "teachers": [{"name": "Qwen/Qwen3-1.7B-Base", "surfaces": ["state", "semantic", "logit"]}],
            "alpha_state": 0.3125, "alpha_semantic": 0.1875, "alpha_logit": 0.5
        },
        "rep_only": {
            "tag": "rep_15k",
            "teachers": [{"name": "Qwen/Qwen3-1.7B-Base", "surfaces": ["state", "semantic"]}],
            "alpha_state": 0.625, "alpha_semantic": 0.375, "alpha_logit": 0.0
        }
    },
    "_monitoring_thresholds": {
        "kurtosis_ratio_yellow": 2.0,
        "kurtosis_ratio_red": 3.0,
        "max_act_ratio_yellow": 1.15,
        "persistence_evidence_10k": 0.02,
        "persistence_proof_15k": 0.015,
        "head_start_threshold": 0.01
    }
}
