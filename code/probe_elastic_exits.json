{
    "name": "elastic_exits",
    "description": "T+L R1 Probe 5: Fixed exits at layers 4 and 9 (0-indexed: 3,8) on 10-layer model. Trains with weighted exit losses. Measures BPT at each exit vs final layer.",
    "variants": [
        {"tag": "dense_no_exits", "norm_type": "rmsnorm", "exit_layers": null},
        {"tag": "exits_4_9", "norm_type": "rmsnorm", "exit_layers": [3, 8]}
    ],
    "dim": 512,
    "n_layers": 10,
    "n_heads": 8,
    "ff_dim": 1536,
    "steps": 5000,
    "eval_every": 500,
    "batch_size": 16,
    "grad_accum": 2,
    "seq_len": 512,
    "lr": 3e-4,
    "min_lr": 1e-5,
    "warmup": 200,
    "use_top": false,
    "top_K": 4,
    "exit_layers": null
}
