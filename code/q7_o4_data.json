{
  "name": "o4_data_shaping_gate",
  "description": "O4 first decision probe: raw vs MiniPLM-reweighted data. Same pure transformer architecture, same steps, different data sampling. Success: MiniPLM variant achieves lower BPT at step 5000.",
  "dim": 512,
  "n_heads": 8,
  "ff_dim": 1536,
  "steps": 5000,
  "eval_every": 500,
  "batch_size": 16,
  "grad_accum": 2,
  "seq_len": 512,
  "lr": 0.0003,
  "min_lr": 1e-05,
  "warmup": 200,
  "norm_type": "ss_rmsnorm",
  "exit_layers": [7, 15, 23],
  "variants": [
    {
      "tag": "raw_24x512",
      "block_schedule": ["A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A"]
    },
    {
      "tag": "miniplm_24x512",
      "block_schedule": ["A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A","A"],
      "weight_file": "results/miniplm_shard_weights.json"
    }
  ]
}
