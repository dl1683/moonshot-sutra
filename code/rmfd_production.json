{
    "_comment": "DRAFT — needs Codex pre-training audit before launch",
    "name": "rmfd_v2_production",
    "init_from": "results/checkpoints_probe_pgqa_100m_gate/transformer_24x512_step5000.pt",
    "resume_from": null,
    "total_steps": 120000,
    "batch_size": 8,
    "grad_accum": 4,
    "lr": 3e-4,
    "min_lr": 1e-5,
    "warmup": 2000,
    "eval_every": 5000,
    "seq_len": 512,
    "n_spans": 16,
    "phases": [
        {
            "name": "stabilization",
            "end_step": 2000,
            "teachers": [],
            "alpha_state": 0.0,
            "alpha_semantic": 0.0,
            "_note": "Pure CE warmup, establish gradient flow from init checkpoint"
        },
        {
            "name": "single_anchor",
            "end_step": 15000,
            "teachers": [
                {"name": "Qwen/Qwen3-1.7B-Base", "surfaces": ["state", "semantic"]}
            ],
            "alpha_state": 0.5,
            "alpha_semantic": 0.3,
            "_note": "Establish KD signal with strongest single teacher"
        },
        {
            "name": "committee",
            "end_step": 96000,
            "teachers": [
                {"name": "Qwen/Qwen3-1.7B-Base", "surfaces": ["state", "semantic"]},
                {"name": "LiquidAI/LFM2.5-1.2B-Base", "surfaces": ["state"]},
                {"name": "google/embeddinggemma-300m", "surfaces": ["semantic"]}
            ],
            "alpha_state": 0.5,
            "alpha_semantic": 0.3,
            "_note": "Full committee with fair loss scaling (alpha/n_teachers per surface)"
        },
        {
            "name": "consolidation",
            "end_step": 120000,
            "teachers": [
                {"name": "Qwen/Qwen3-1.7B-Base", "surfaces": ["state", "semantic"]}
            ],
            "alpha_state": 0.25,
            "alpha_semantic": 0.15,
            "_note": "Decay to single anchor, reduce KD weight, LR decay phase crystallizes"
        }
    ]
