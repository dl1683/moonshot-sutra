{
    "name": "trunk_choice",
    "description": "Probe 1: Does the hybrid trunk beat pure transformer and pure gated-conv at ~42M scale?",
    "variants": [
        {
            "tag": "pure_transformer",
            "block_schedule": ["A","A","A","A","A","A","A","A","A","A","A","A"]
        },
        {
            "tag": "pure_conv",
            "block_schedule": ["H","H","H","H","H","H","H","H","H","H","H","H"]
        },
        {
            "tag": "hybrid_3to1",
            "block_schedule": ["H","H","A","H","H","H","A","H","H","H","A","H"]
        }
    ],
    "dim": 512,
    "n_layers": 12,
    "n_heads": 8,
    "ff_dim": 1536,
    "conv_kernel_size": 64,
    "steps": 5000,
    "eval_every": 500,
    "batch_size": 16,
    "grad_accum": 2,
    "seq_len": 512,
    "lr": 3e-4,
    "min_lr": 1e-5,
    "warmup": 200,
    "use_top": false,
    "top_K": 4
}
