  "key_insights": {
    "best_sub200M_overall": "SmolLM2-135M (HellaSwag 42.1, PIQA 68.4) and MobileLLM-LS-125M (ARC-E 45.8, ARC-C 28.7) are the two strongest sub-200M models",
    "training_data_matters": "SmolLM2 on 2T tokens >> Pythia on 300B tokens. SmolLM2 with 135M params beats Pythia-410M on HellaSwag (42.1 vs 40.1)",
    "depth_matters": "MobileLLM (30 layers, 576d) dramatically outperforms same-param models with fewer layers (e.g., Pythia-160M: 12 layers, 768d). +9pp on HellaSwag.",
    "sutra_architecture_comparison": "Sutra-24A-90M (24 layers, 512d) is between Pythia-70M (6L/512d) and Pythia-160M (12L/768d) in capacity. 197M target would be comparable to MobileLLM-125M in param count but needs 10x more training data.",
    "target_benchmarks_for_197M": {
      "floor_must_beat": {
        "ARC-Easy": 40.0,
